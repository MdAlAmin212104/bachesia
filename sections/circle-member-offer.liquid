<script>
(() => {
  const root = document.querySelector('[data-circle-section="{{ sid }}"]');
  if (!root) return;

  const sid = '{{ sid }}';
  const STORAGE_KEY = 'circle_access_' + sid;
  const ACCESS_DURATION = 24 * 60 * 60 * 1000;

  const gateEl = document.getElementById('circle-code-gate-' + sid);
  const offerEl = document.getElementById('circle-offer-content-' + sid);
  const codeInput = document.getElementById('circle-code-input-' + sid);
  const submitBtn = document.getElementById('circle-code-submit-' + sid);
  const errorEl = document.getElementById('circle-code-error-' + sid);

  const rawCodes = (root.dataset.accessCodes || '').trim();
  const validCodes = rawCodes.length
    ? rawCodes.split(',').map(c => c.trim().toUpperCase()).filter(Boolean)
    : [];

  // ── localStorage check ──
  function isVerified() {
    try {
      const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null');
      if (!saved || !saved.code || !saved.expires || !saved.codeList) return false;
      if (Date.now() > saved.expires) {
        localStorage.removeItem(STORAGE_KEY);
        return false;
      }
      if (saved.codeList !== rawCodes) {
        localStorage.removeItem(STORAGE_KEY);
        return false;
      }
      if (!validCodes.includes(saved.code)) {
        localStorage.removeItem(STORAGE_KEY);
        return false;
      }
      return true;
    } catch (e) {
      localStorage.removeItem(STORAGE_KEY);
      return false;
    }
  }

  function grantAccess(code) {
    if (code) {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify({
          code: code.toUpperCase(),
          codeList: rawCodes,
          expires: Date.now() + ACCESS_DURATION
        }));
      } catch (e) {}
    }
    if (gateEl) gateEl.style.display = 'none';
    if (offerEl) offerEl.style.display = 'block';
    initOffer();
  }

  function showGate() {
    if (gateEl) gateEl.style.display = 'block';
    if (offerEl) offerEl.style.display = 'none';
  }

  if (!validCodes.length || isVerified()) {
    grantAccess(null);
  } else {
    showGate();
  }

  function tryCode() {
    if (!codeInput) return;
    const entered = codeInput.value.trim().toUpperCase();
    if (!entered) {
      codeInput.focus();
      return;
    }
    if (validCodes.includes(entered)) {
      if (errorEl) errorEl.style.display = 'none';
      codeInput.classList.remove('error');
      grantAccess(entered);
    } else {
      if (errorEl) errorEl.style.display = 'block';
      codeInput.classList.add('error');
      codeInput.value = '';
      codeInput.focus();
      setTimeout(() => codeInput.classList.remove('error'), 400);
    }
  }

  if (submitBtn) submitBtn.addEventListener('click', tryCode);
  if (codeInput) {
    codeInput.addEventListener('keydown', e => {
      if (e.key === 'Enter') tryCode();
    });
    codeInput.addEventListener('input', () => {
      codeInput.value = codeInput.value.toUpperCase();
    });
  }

  // ── Main offer ────────────────────────────────────────────────────────────
  function initOffer() {
    const dataEl = document.getElementById('CircleProducts-' + sid);
    if (!dataEl) return;

    let products = [];
    try {
      products = JSON.parse(dataEl.textContent.trim());
    } catch (e) {
      console.error('Circle products JSON error:', e);
      return;
    }
    if (!products.length) return;

    const moneyFormat = {{ shop.money_format | json }};
    const discountPercent = Number(root.dataset.discountPercent || 0);
    const discountCode = root.dataset.discountCode || '';
    const buttonAction = root.dataset.buttonAction || 'cart';
    const activePhase = Number(root.dataset.activePhase || '0');
    const shippingText = root.dataset.shippingText || 'In your hands in ~14 days';
    const tagline = root.dataset.tagline || 'Yours before<br><em>the rest of the world.</em>';

    const mainReserveBtn = root.querySelector('[data-reserve-main]');
    const scarcityText = root.querySelector('[data-scarcity-text]');
    const optionsContainer = root.querySelector('[data-options-container]');
    const previewBox = root.querySelector('[data-preview-box]');
    const previewImg = root.querySelector('[data-preview-img]');
    const previewTitle = root.querySelector('[data-preview-title]');
    const previewVariant = root.querySelector('[data-preview-variant]');
    const previewSalePrice = root.querySelector('[data-preview-sale-price]');
    const previewWas = root.querySelector('[data-preview-compare-price]');
    const previewSavings = root.querySelector('[data-preview-savings]');
    const viewDetailsBtn = root.querySelector('[data-view-details]');
    const dotsContainer = root.querySelector('[data-slider-dots]');
    const track = root.querySelector('[data-slider-track]');
    const viewport = root.querySelector('[data-slider-viewport]');
    const prevBtn = root.querySelector('[data-arrow="prev"]');
    const nextBtn = root.querySelector('[data-arrow="next"]');
    const cards = root.querySelectorAll('.circle-prod[data-product-index]');

    // Modals
    const productModal = document.getElementById('circle-product-modal-' + sid);
    const productModalClose = document.getElementById('circle-modal-close-' + sid);
    const sizeModal = document.getElementById('circle-size-modal-' + sid);
    const sizeModalClose = document.getElementById('circle-size-close-' + sid);

    let selectedProduct = null;
    let selectedOptions = [];
    let selectedVariant = null;
    let currentSlide = 0;

    // ── Money formatting ───────────────────────────────────────────────────
    function formatMoney(cents) {
      if (window.Shopify && typeof window.Shopify.formatMoney === 'function') {
        return window.Shopify.formatMoney(cents, moneyFormat);
      }
      
      const value = Math.round(Number(cents) || 0);
      const whole = Math.floor(value / 100);
      const dec = String(value % 100).padStart(2, '0');
      const withComma = s => String(s).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
      
      // Check if amount is a whole number (no decimal)
      const isWholeNumber = dec === '00';
      
      let formattedAmount;
      if (moneyFormat && (moneyFormat.includes('amount_no_decimals') || isWholeNumber)) {
        formattedAmount = withComma(whole);
      } else {
        formattedAmount = withComma(whole) + '.' + dec;
      }
      
      let result = moneyFormat
        .replace(/\{\{\s*amount_with_comma_separator\s*\}\}/g, withComma(whole) + ',' + dec)
        .replace(/\{\{\s*amount_no_decimals_with_comma_separator\s*\}\}/g, withComma(whole).replace(/,/g, '.'))
        .replace(/\{\{\s*amount_no_decimals_with_space_separator\s*\}\}/g, withComma(whole).replace(/,/g, ' '))
        .replace(/\{\{\s*amount_no_decimals\s*\}\}/g, withComma(whole))
        .replace(/\{\{\s*amount_with_apostrophe_separator\s*\}\}/g, withComma(whole).replace(/,/g, "'") + '.' + dec)
        .replace(/\{\{\s*amount\s*\}\}/g, formattedAmount);
      
      // Remove .00 from the final result
      if (isWholeNumber) {
        result = result.replace(/\.00/g, '');
      }
      
      return result;
    }

    function discountedPrice(priceCents, customDiscount = null) {
      const disc = customDiscount !== null ? customDiscount : discountPercent;
      if (!disc || disc === 0) return Number(priceCents || 0);
      return Math.round(Number(priceCents || 0) * (100 - disc) / 100);
    }

    // ── Slider functions ───────────────────────────────────────────────────
    function getVisibleCount() {
      return window.innerWidth <= 480 ? 2 : 4;
    }

    function maxSlide() { 
      const visible = getVisibleCount();
      const total = cards.length;
      if (total <= visible) return 0;
      return total - visible; 
    }

    function buildDots() {
      if (!dotsContainer) return;
      dotsContainer.innerHTML = '';
      const max = maxSlide();
      const pages = max + 1;
      
      if (pages <= 1) { 
        dotsContainer.style.display = 'none'; 
        if (prevBtn) prevBtn.disabled = true;
        if (nextBtn) nextBtn.disabled = true;
        return; 
      }
      
      dotsContainer.style.display = 'flex';
      if (prevBtn) prevBtn.disabled = false;
      if (nextBtn) nextBtn.disabled = false;
      
      for (let i = 0; i < pages; i++) {
        const dot = document.createElement('button');
        dot.className = 'circle-slider-dot' + (i === currentSlide ? ' active' : '');
        dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
        dot.addEventListener('click', (function(idx) { 
          return function() { goTo(idx); }; 
        })(i));
        dotsContainer.appendChild(dot);
      }
    }

    function updateDots() {
      if (!dotsContainer) return;
      dotsContainer.querySelectorAll('.circle-slider-dot').forEach((d, i) => {
        d.classList.toggle('active', i === currentSlide);
      });
    }

    function goTo(index) {
      const max = maxSlide();
      if (max === 0) {
        currentSlide = 0;
        if (track) track.style.transform = `translateX(0px)`;
        if (prevBtn) prevBtn.disabled = true;
        if (nextBtn) nextBtn.disabled = true;
        if (dotsContainer) dotsContainer.style.display = 'none';
        return;
      }

      currentSlide = Math.max(0, Math.min(index, max));
      const allCards = track ? Array.from(track.querySelectorAll('.circle-prod')) : [];
      if (!allCards.length) return;
      const gap = 10;
      const cardWidth = allCards[0].getBoundingClientRect().width;
      if (track) track.style.transform = `translateX(-${currentSlide * (cardWidth + gap)}px)`;
      if (prevBtn) prevBtn.disabled = currentSlide === 0;
      if (nextBtn) nextBtn.disabled = currentSlide >= max;
      updateDots();
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        if (currentSlide > 0) goTo(currentSlide - 1);
      });
    }
    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        if (currentSlide < maxSlide()) goTo(currentSlide + 1);
      });
    }

    if (viewport) {
      let touchStartX = 0;
      viewport.addEventListener('touchstart', e => {
        touchStartX = e.touches[0].clientX;
      }, { passive: true });
      viewport.addEventListener('touchend', e => {
        const diff = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 40) {
          diff > 0 ? goTo(currentSlide + 1) : goTo(currentSlide - 1);
        }
      }, { passive: true });
    }

    setTimeout(() => {
      buildDots();
      goTo(0);
    }, 80);

    window.addEventListener('resize', function() {
      buildDots();
      const max = maxSlide();
      if (currentSlide > max) {
        goTo(0);
      } else {
        goTo(Math.min(currentSlide, max));
      }
    });

        // ── Update size guide title with product name ──────────────────────
    function updateSizeGuideTitle(productName) {
      const titleEl = document.getElementById('size-guide-title-' + sid);
      if (titleEl && productName) {
        titleEl.textContent = productName + ' — Size Guide';
      } else if (titleEl) {
        titleEl.textContent = '{{ section.settings.size_guide_title | default: 'Size Guide' }}';
      }
    }

    // ── Product selection ──────────────────────────────────────────────────
    {% comment %} function selectProduct(index) {
      const product = products[index];
      if (!product) return;
      selectedProduct = product;
      
