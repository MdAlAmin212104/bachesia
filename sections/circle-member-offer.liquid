    <script type="application/json" id="CircleProducts-{{ sid }}">
      [
        {% assign printed_first = false %}
        {% for product in offer_collection.products %}
          {% if section.settings.hide_sold_out_products and product.available == false %}{% continue %}{% endif %}
          {% if printed_first %},{% endif %}
          {% assign printed_first = true %}
          {
            "id": {{ product.id | json }},
            "title": {{ product.title | json }},
            "url": {{ product.url | json }},
            "available": {{ product.available | json }},
            "price": {{ product.price_min | json }},
            "compare_at_price": {{ product.compare_at_price_max | default: product.price_min | json }},
            "description": {{ product.description | strip_html | json }},
            "options": {{ product.options | json }},
            "images": [
              {% assign printed_img_first = false %}
              {% for image in product.images limit: 8 %}
                {% if printed_img_first %},{% endif %}
                {% assign printed_img_first = true %}
                { "src": {{ image | image_url: width: 1200 | json }}, "alt": {{ image.alt | default: product.title | json }} }
              {% endfor %}
            ],
            "variants": [
              {% assign printed_var_first = false %}
              {% for variant in product.variants %}
                {% if printed_var_first %},{% endif %}
                {% assign printed_var_first = true %}
                {
                  "id": {{ variant.id | json }},
                  "title": {{ variant.title | json }},
                  "available": {{ variant.available | json }},
                  "price": {{ variant.price | json }},
                  "compare_at_price": {{ variant.compare_at_price | default: product.compare_at_price_max | default: variant.price | json }},
                  "inventory_quantity": {{ variant.inventory_quantity | json }},
                  "featured_image": {% if variant.featured_image %}{{ variant.featured_image | image_url: width: 500 | json }}{% else %}null{% endif %},
                  "options": {{ variant.options | json }}
                }
              {% endfor %}
            ]
          }
        {% endfor %}
      ]
    </script>
  {% endif %}
