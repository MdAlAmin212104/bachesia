    function selectProduct(index) {
  const product = products[index];
  if (!product) return;
  selectedProduct = product;
  
  // Update size guide title with selected product name
  updateSizeGuideTitle(product.title);
  
  // সব কার্ড থেকে active ক্লাস রিমুভ করুন
  cards.forEach(card => {
    card.classList.remove('active');
  });
  
  // সিলেক্ট করা কার্ডে active ক্লাস যোগ করুন
  const selectedCard = root.querySelector(`[data-product-index="${index}"]`);
  if (selectedCard) {
    selectedCard.classList.add('active');
  }
  
  // সব কার্ডের স্ট্যাটাস আপডেট করুন
  cards.forEach((card, idx) => {
    const wrapper = card.querySelector('.prod-status-wrapper');
    if (!wrapper) return;
    
    const activeStatus = wrapper.querySelector('.status-active');
    const shippingStatus = wrapper.querySelector('.status-shipping');
    
    if (idx === index) {
      // সিলেক্ট করা কার্ড - "Tap to view →" দেখান
      if (activeStatus) activeStatus.style.display = 'block';
      if (shippingStatus) shippingStatus.style.display = 'none';
    } else {
      // বাকি কার্ড - শিপিং ডেট দেখান
      if (activeStatus) activeStatus.style.display = 'none';
      if (shippingStatus) shippingStatus.style.display = 'block';
    }
  });
  
  const init = product.variants.find(v => v.available) || product.variants[0];
  selectedOptions = init ? [...init.options] : [];
  renderOptions();
  updateSelectedVariant();
}


    // ── Update all prices based on selected variant ────────────────────────
    function updateAllPrices() {
      if (!selectedVariant) return;

      const basePrice = selectedVariant.price;

      if (previewSalePrice) {
        const currentPrice = discountedPrice(basePrice);
        previewSalePrice.textContent = formatMoney(currentPrice);
      }

      if (previewWas) {
        previewWas.textContent = formatMoney(basePrice);
      }

      if (previewSavings) {
        const currentPrice = discountedPrice(basePrice);
        const savings = basePrice - currentPrice;
        if (discountPercent > 0 && savings > 0) {
          previewSavings.textContent = `Save ${formatMoney(savings)}`;
          previewSavings.style.display = 'inline-block';
        } else {
          previewSavings.style.display = 'none';
        }
      }

      const stripCells = root.querySelectorAll('[data-strip-price]');
      stripCells.forEach(cell => {
        const phase = cell.getAttribute('data-strip-price');
        if (phase === 'public') {
          cell.textContent = formatMoney(basePrice);
        } else {
          const phaseDiscount = Number(cell.getAttribute('data-phase-discount') || 0);
          if (phaseDiscount > 0) {
            const discounted = Math.round(basePrice * (100 - phaseDiscount) / 100);
            cell.textContent = formatMoney(discounted);
          } else {
            cell.textContent = formatMoney(basePrice);
          }
        }
      });

      const activeCard = root.querySelector('.circle-prod.active');
      if (activeCard) {
        const priceSpan = activeCard.querySelector('[data-product-price-display]');
        const compareS = activeCard.querySelector('[data-product-compare-price-display]');
        if (priceSpan) {
          priceSpan.textContent = formatMoney(discountedPrice(basePrice));
        }
        if (compareS && discountPercent > 0) {
          compareS.textContent = formatMoney(basePrice);
        }
      }

      const lockedRows = root.querySelectorAll('.circle-locked-row');
      lockedRows.forEach(row => {
        const priceEl = row.querySelector('[data-locked-price-2], [data-locked-price-3], [data-locked-price]');
        if (priceEl && priceEl.textContent !== 'Closed') {
          const phaseDiscount = Number(priceEl.getAttribute('data-phase-discount') || 0);
          let discountedPriceValue = basePrice;
          let badgeText = '';

          if (phaseDiscount > 0) {
            discountedPriceValue = Math.round(basePrice * (100 - phaseDiscount) / 100);
            badgeText = phaseDiscount + '% off';
          } else if (phaseDiscount === 0) {
            discountedPriceValue = basePrice;
            badgeText = 'Full price';
          }

          priceEl.textContent = formatMoney(discountedPriceValue);

          const badge = row.querySelector('[data-locked-badge-2], [data-locked-badge-3], [data-locked-badge]');
          if (badge && badgeText) {
            badge.textContent = badgeText;
            badge.style.display = 'inline-block';
          }
        }
      });
    }

    // ── Product selection ──────────────────────────────────────────────────
    function selectProduct(index) {
      const product = products[index];
      if (!product) return;
      selectedProduct = product;
      updateSizeGuideTitle(product.title);
      cards.forEach(card => {
        card.classList.toggle('active', Number(card.dataset.productIndex) === index);
      });
      const init = product.variants.find(v => v.available) || product.variants[0];
      selectedOptions = init ? [...init.options] : [];
      renderOptions();
      updateSelectedVariant();
    }

    function looksLikeColor(val) {
      const s = document.createElement('span');
      s.style.color = val.toLowerCase().replace(/\s/g, '');
      return s.style.color !== '' || /^#[0-9a-f]{3,8}$/i.test(val);
    }

    function isSizeOption(name) {
      return /size|maat|taille|größe|taglia/i.test(name);
    }

    function renderOptions() {
      if (!optionsContainer || !selectedProduct) return;
      const isDefaultOnly = selectedProduct.variants.length === 1 && selectedProduct.variants[0].title === 'Default Title';
      if (isDefaultOnly) {
        optionsContainer.innerHTML = '';
        return;
      }

      const hasSizeOption = selectedProduct.options.some(o => isSizeOption(o));

      let html = '<div class="circle-options-inner">';
      
      selectedProduct.options.forEach((optName, optIdx) => {
        const values = [...new Set(selectedProduct.variants.map(v => v.options[optIdx]))];
        const selectedVal = selectedOptions[optIdx];
        
        html += `<div class="circle-option-group">`;
        html += `<div class="circle-option-group-header" style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 10px;">`;
        html += `<div class="circle-option-group-label">Select ${escapeHtml(optName)}<strong>${selectedVal ? ' — ' + escapeHtml(selectedVal) : ''}</strong></div>`;
        
        if (isSizeOption(optName) && hasSizeOption && {{ section.settings.size_guide_content | json }} !== 'null' && {{ section.settings.size_guide_content | json }} !== '') {
          html += `<button type="button" class="circle-size-guide-link" id="circle-size-guide-trigger-${sid}">Size guide</button>`;
        }
        
        html += `</div><div class="circle-option-values">`;
        
        const isSize = isSizeOption(optName);
        values.forEach(val => {
          const matchingVariants = selectedProduct.variants.filter(v =>
            selectedProduct.options.every((_, i) => i === optIdx ? v.options[i] === val : (selectedOptions[i] == null || v.options[i] === selectedOptions[i]))
          );
          const isAvailable = matchingVariants.some(v => v.available);
          const totalQty = matchingVariants.reduce((s, v) => s + Number(v.inventory_quantity || 0), 0);
          const isSelected = selectedOptions[optIdx] === val;
          const isLastUnit = isAvailable && totalQty > 0 && totalQty <= 5;
          const isColor = looksLikeColor(val);

          if (isSize) {
            let cls = 'circle-sz';
            if (isSelected) cls += ' active';
            if (!isAvailable) cls += ' sold-out';
            else if (isLastUnit) cls += ' last-unit';
            html += `<button type="button" class="${cls}" data-opt-idx="${optIdx}" data-opt-val="${escapeHtml(val)}"${!isAvailable ? ' disabled' : ''}><span>${escapeHtml(val)}</span><span class="circle-sz-dot"></span></button>`;
          } else {
            let cls = 'circle-option-value-btn';
            if (isSelected) cls += ' active';
            if (!isAvailable) cls += ' sold-out';
            else if (isLastUnit) cls += ' last-unit';
            if (isColor) cls += ' is-color';
            if (isColor) {
              html += `<button type="button" class="${cls}" data-opt-idx="${optIdx}" data-opt-val="${escapeHtml(val)}" title="${escapeHtml(val)}"><span class="circle-color-swatch" style="background:${val.toLowerCase().replace(/\s/g, '')}"></span></button>`;
            } else {
              html += `<button type="button" class="${cls}" data-opt-idx="${optIdx}" data-opt-val="${escapeHtml(val)}"><span class="circle-option-dot"></span>${escapeHtml(val)}</button>`;
            }
          }
        });
        html += '</div></div>';
      });
      
      html += '<div class="circle-size-legend"><span><span class="circle-legend-dot last-unit"></span> Last units</span><span><span class="circle-legend-dot sold-out"></span> Sold out</span></div>';
      html += '</div>';
      optionsContainer.innerHTML = html;

      optionsContainer.querySelectorAll('[data-opt-idx]').forEach(btn => {
        btn.addEventListener('click', () => {
          if (btn.classList.contains('sold-out') || btn.disabled) return;
          selectedOptions[Number(btn.dataset.optIdx)] = btn.dataset.optVal;
          renderOptions();
          updateSelectedVariant();
        });
      });

      const sgt = document.getElementById('circle-size-guide-trigger-' + sid);
      if (sgt && sizeModal) {
        sgt.addEventListener('click', () => openModal(sizeModal));
      }
    }

    function escapeHtml(str) {
      if (!str) return '';
      return str.replace(/[&<>]/g, function(m) {
        if (m === '&') return '&amp;';
        if (m === '<') return '&lt;';
        if (m === '>') return '&gt;';
        return m;
      });
    }

    function updateSelectedVariant() {
      if (!selectedProduct) return;
      let variant = selectedProduct.variants.find(v => v.options.every((optVal, idx) => optVal === selectedOptions[idx]));
      if (!variant) variant = selectedProduct.variants.find(v => v.available) || selectedProduct.variants[0];
      selectedVariant = variant;
      if (!selectedVariant) return;

      updateAllPrices();

      const activeCard = root.querySelector('.circle-prod.active');
      if (activeCard) {
        const cardImg = activeCard.querySelector('[data-product-featured-image]');
        if (cardImg) {
          const src = selectedVariant.featured_image || (selectedProduct.images[0] && selectedProduct.images[0].src);
          if (src) cardImg.src = src;
        }
      }

      const qty = Number(selectedVariant.inventory_quantity || 0);
      if (scarcityText) {
        scarcityText.textContent = !selectedVariant.available
          ? 'This variant is sold out.'
          : (qty > 0 && qty <= 5)
            ? `⚠ Only ${qty} unit${qty !== 1 ? 's' : ''} left in stock`
            : 'Available now — members only.';
      }

      if (previewBox) {
        previewBox.style.display = 'flex';
        const imgSrc = selectedVariant.featured_image || (selectedProduct.images[0] && selectedProduct.images[0].src) || '';
        if (previewImg) {
          previewImg.src = imgSrc;
          previewImg.alt = selectedProduct.title;
        }
        if (previewTitle) previewTitle.textContent = selectedProduct.title;
        if (previewVariant) previewVariant.textContent = selectedVariant.title === 'Default Title' ? 'Standard' : selectedVariant.title;
      }

      function getFirstThreeWords(str) {
        if (!str) return '';
        const words = str.split(' ').filter(word => word.length > 0);
        const firstThree = words.slice(0, 3).join(' ');
        return firstThree;
      }

      if (mainReserveBtn) {
        mainReserveBtn.disabled = !selectedVariant.available;
        if (!selectedVariant.available) {
          mainReserveBtn.textContent = 'Sold out';
        } else if (discountPercent > 0) {
          const shortTitle = getFirstThreeWords(selectedProduct.title);
          const variantText = selectedVariant.title === 'Default Title' ? '' : ` / ${selectedVariant.title}`;
          mainReserveBtn.textContent = `Secure my pair - ${shortTitle}${variantText}`;
        } else {
          const shortTitle = getFirstThreeWords(selectedProduct.title);
          const variantText = selectedVariant.title === 'Default Title' ? '' : ` — ${selectedVariant.title}`;
          mainReserveBtn.textContent = `Reserve /${shortTitle}${variantText}`;
        }
      }
    }

    // ── Reserve / cart ─────────────────────────────────────────────────────
    async function reserveProduct() {
      if (!selectedProduct || !selectedVariant || !selectedVariant.available) return;
      if (buttonAction === 'product') {
        window.location.href = discountCode
          ? `/discount/${encodeURIComponent(discountCode)}?redirect=${encodeURIComponent(selectedProduct.url)}`
          : selectedProduct.url;
        return;
      }
      if (mainReserveBtn) {
        mainReserveBtn.disabled = true;
        mainReserveBtn.textContent = 'Adding…';
      }
      try {
        if (discountCode) {
          try {
            await fetch(`/discount/${encodeURIComponent(discountCode)}`);
          } catch (e) {
            console.error('Failed to apply discount in background:', e);
          }
        }

        const res = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({
            id: selectedVariant.id,
            quantity: 1,
            properties: {
              '_Circle phase': `Phase ${activePhase}`,
              '_Circle discount': discountPercent ? `${discountPercent}%` : 'None'
            }
          })
        });
        if (!res.ok) throw new Error('Cart error');

        document.body.dispatchEvent(new CustomEvent('baseline:modalcart:afteradditem'));

        if (window.Spruce && window.Spruce.store('drawer')) {
          window.Spruce.store('drawer').cartDrawerOpen = true;
        }

        if (mainReserveBtn) {
          mainReserveBtn.disabled = false;
          if (discountPercent > 0) {
            mainReserveBtn.textContent = `Secure my pair`;
          } else {
            const vLabel = selectedVariant.title === 'Default Title' ? '' : ` — ${selectedVariant.title}`;
            mainReserveBtn.textContent = `Secure my pair${vLabel}`;
          }
        }
      } catch (err) {
        console.error(err);
        if (mainReserveBtn) {
          mainReserveBtn.disabled = false;
          mainReserveBtn.textContent = 'Try again';
        }
      }
    }

    cards.forEach(card => card.addEventListener('click', () => selectProduct(Number(card.dataset.productIndex))));
    if (mainReserveBtn) mainReserveBtn.addEventListener('click', reserveProduct);

    // ── Product details buttons on cards ──────────────────────────────────────────
    const prodDetailsBtns = root.querySelectorAll('[data-prod-details-btn]');
    prodDetailsBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const productIndex = btn.getAttribute('data-product-index');
        if (productIndex !== null && products[parseInt(productIndex)]) {
          const product = products[parseInt(productIndex)];
          const defaultVariant = product.variants.find(v => v.available) || product.variants[0];
          openProductModal(product, defaultVariant);
        }
      });
    });

    // ── Product details modal ──────────────────────────────────────────────
    function openProductModal(product, variant) {
      if (!productModal) return;
      const imgTrack = productModal.querySelector('[data-modal-img-track]');
      const imgPrev = productModal.querySelector('[data-modal-img-prev]');
      const imgNext = productModal.querySelector('[data-modal-img-next]');
      const imgDots = productModal.querySelector('[data-modal-img-dots]');
      const modalExclusive = productModal.querySelector('[data-modal-exclusive]');
      const modalTagline = productModal.querySelector('[data-modal-tagline]');
      const modalShippingText = productModal.querySelector('[data-modal-shipping-text]');
      const modalTitle = productModal.querySelector('[data-modal-title]');
      const modalSale = productModal.querySelector('[data-modal-sale]');
      const modalWas = productModal.querySelector('[data-modal-was]');
      const modalDesc = productModal.querySelector('[data-modal-desc]');

      const images = product.images && product.images.length ? product.images : [];
      let modalImgIdx = 0;

      let orderedImgs = [...images];
      if (variant && variant.featured_image) {
        orderedImgs = [{ src: variant.featured_image, alt: product.title }, ...images.filter(i => i.src !== variant.featured_image)];
      }

      if (imgTrack) {
        imgTrack.innerHTML = orderedImgs.map(img =>
          `<img src="${img.src}" alt="${img.alt || product.title}" loading="lazy">`
        ).join('');
        imgTrack.style.transform = 'translateX(0)';
      }

      function goModalImg(idx) {
        modalImgIdx = Math.max(0, Math.min(idx, orderedImgs.length - 1));
        if (imgTrack) imgTrack.style.transform = `translateX(-${modalImgIdx * 100}%)`;
        if (imgDots) imgDots.querySelectorAll('.circle-modal-img-dot').forEach((d, i) => d.classList.toggle('active', i === modalImgIdx));
        if (imgPrev) imgPrev.style.display = modalImgIdx > 0 ? 'flex' : 'none';
        if (imgNext) imgNext.style.display = modalImgIdx < orderedImgs.length - 1 ? 'flex' : 'none';
      }

      if (imgDots) {
        imgDots.innerHTML = orderedImgs.length > 1
          ? orderedImgs.map((_, i) => `<button type="button" class="circle-modal-img-dot${i === 0 ? ' active' : ''}" aria-label="Image ${i + 1}"></button>`).join('')
          : '';
        imgDots.querySelectorAll('.circle-modal-img-dot').forEach((d, i) => d.addEventListener('click', () => goModalImg(i)));
      }
      if (imgPrev) {
        imgPrev.onclick = () => goModalImg(modalImgIdx - 1);
        imgPrev.style.display = 'none';
      }
      if (imgNext) {
        imgNext.onclick = () => goModalImg(modalImgIdx + 1);
        imgNext.style.display = orderedImgs.length > 1 ? 'flex' : 'none';
      }

      if (imgTrack) {
        let tStart = 0;
        imgTrack.addEventListener('touchstart', e => {
          tStart = e.touches[0].clientX;
        }, { passive: true });
        imgTrack.addEventListener('touchend', e => {
          const diff = tStart - e.changedTouches[0].clientX;
          if (Math.abs(diff) > 40) {
            diff > 0 ? goModalImg(modalImgIdx + 1) : goModalImg(modalImgIdx - 1);
          }
        }, { passive: true });
      }

      if (modalExclusive) {
        modalExclusive.innerHTML = discountPercent > 0
          ? `<div class="modal-exclusive-dot"></div> Exclusively for Circle Members`
          : `<div class="modal-exclusive-dot"></div> Circle Members Only`;
      }

      if (modalTagline) {
        modalTagline.innerHTML = tagline;
      }

      if (modalShippingText) {
        modalShippingText.textContent = shippingText;
      }

      if (modalTitle) modalTitle.textContent = product.title;

      updateSizeGuideTitle(product.title);

      const currentPrice = variant ? discountedPrice(variant.price) : discountedPrice(product.price);
      const originalPrice = variant ? variant.price : product.price;

      if (modalSale) modalSale.textContent = formatMoney(currentPrice);
      if (modalWas) {
        modalWas.textContent = discountPercent > 0 ? formatMoney(originalPrice) : formatMoney(currentPrice);
        if (!discountPercent || discountPercent === 0) {
          modalWas.style.color = 'var(--muted)';
        }
      }

      if (modalDesc) {
        // Use innerHTML to preserve formatting and show full description
        modalDesc.innerHTML = product.description || '';
      }

      openModal(productModal);
    }

    if (viewDetailsBtn) {
      viewDetailsBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        if (selectedProduct) {
          openProductModal(selectedProduct, selectedVariant);
        }
      });
    }

    // ── Modal helpers ──────────────────────────────────────────────────────
    function openModal(modal) {
      if (!modal) return;
      modal.style.display = 'flex';
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => modal.querySelector('.circle-modal').style.animation = `circleModalIn-{{ sid }} .28s cubic-bezier(.25,1,.5,1)`);
    }

    function closeModal(modal) {
      if (!modal) return;
      modal.style.display = 'none';
      document.body.style.overflow = '';
    }

    if (productModalClose) productModalClose.addEventListener('click', () => closeModal(productModal));
    if (sizeModalClose) sizeModalClose.addEventListener('click', () => closeModal(sizeModal));

    [productModal, sizeModal].forEach(modal => {
      if (!modal) return;
      modal.addEventListener('click', e => {
        if (e.target === modal) closeModal(modal);
      });
    });

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') {
        closeModal(productModal);
        closeModal(sizeModal);
      }
    });

    // ── Countdown ──────────────────────────────────────────────────────────
    function updateCountdown() {
      const endMs = Number(root.dataset.activeEndMs || 0);
      if (!endMs) return;
      const diff = Math.max(0, endMs - Date.now());
      const pad = n => String(n).padStart(2, '0');
      const set = (sel, val) => {
        const el = root.querySelector(sel);
        if (el) el.textContent = pad(val);
      };
      set('[data-days]', Math.floor(diff / 86400000));
      set('[data-hours]', Math.floor((diff % 86400000) / 3600000));
      set('[data-minutes]', Math.floor((diff % 3600000) / 60000));
      set('[data-seconds]', Math.floor((diff % 60000) / 1000));
      if (diff <= 0 && mainReserveBtn) {
        mainReserveBtn.disabled = true;
        mainReserveBtn.textContent = 'Offer ended';
      }
    }
    updateCountdown();
    setInterval(updateCountdown, 1000);

    // Initialize with first product
    selectProduct(0);
  }

      // ── Size Guide Unit Toggle ──────────────────────────────────────────
    window.setSizeUnit = function(sid, unit) {
      const cells = document.querySelectorAll('.sz-cell-' + sid);
      const cmBtn = document.getElementById('size-btn-cm-' + sid);
      const inBtn = document.getElementById('size-btn-in-' + sid);
      const label = document.getElementById('size-unit-label-' + sid);
      
      cells.forEach(cell => {
        const cm = parseFloat(cell.dataset.cm);
        if (unit === 'in') {
          cell.textContent = (cm / 2.54).toFixed(2);
        } else {
          cell.textContent = cm % 1 === 0 ? cm : cm.toFixed(2);
        }
      });
      
      if (label) {
        label.textContent = unit === 'cm' ? 'centimetres (cm)' : 'inches (in)';
      }
      
      if (cmBtn) {
        cmBtn.className = unit === 'cm' ? 'active' : 'inactive';
      }
      if (inBtn) {
        inBtn.className = unit === 'in' ? 'active' : 'inactive';
      }
    };

    // ── Override size guide open/close ──────────────────────────────────
    const sizeModal = document.getElementById('circle-size-modal-' + sid);
    const sizeCloseBtn = document.getElementById('circle-size-close-' + sid);
    
    if (sizeCloseBtn) {
      sizeCloseBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        closeModal(sizeModal);
      });
    }
    
    if (sizeModal) {
      sizeModal.addEventListener('click', function(e) {
        if (e.target === this) {
          closeModal(this);
        }
      });
    }
    
    // Override the size guide link in renderOptions to use the modal
    const originalRenderOptions = renderOptions;
    renderOptions = function() {
      originalRenderOptions.call(this);
      
      // Re-attach size guide link to use the modal
      const sizeGuideLinks = document.querySelectorAll('.circle-size-guide-link');
      sizeGuideLinks.forEach(link => {
        link.addEventListener('click', function(e) {
          e.preventDefault();
          const modal = document.getElementById('circle-size-modal-' + sid);
          if (modal) {
            if (selectedProduct) {
              updateSizeGuideTitle(selectedProduct.title);
            }
            openModal(modal);
          };
        });
      });
    };
})();
