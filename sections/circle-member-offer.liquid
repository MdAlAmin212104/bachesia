{% liquid
  assign sid = section.id
  assign now_ts = 'now' | date: '%s' | plus: 0
  assign p1_start_ts = 0
  assign p1_end_ts = 0
  assign p2_start_ts = 0
  assign p2_end_ts = 0
  assign p3_start_ts = 0
  assign p3_end_ts = 0

  if section.settings.phase_1_start != blank
    assign p1_start_ts = section.settings.phase_1_start | append: ' 00:00:00' | date: '%s' | plus: 0
  endif
  if section.settings.phase_1_end != blank
    assign p1_end_ts = section.settings.phase_1_end | append: ' 23:59:59' | date: '%s' | plus: 0
  endif
  if section.settings.phase_2_start != blank
    assign p2_start_ts = section.settings.phase_2_start | append: ' 00:00:00' | date: '%s' | plus: 0
  endif
  if section.settings.phase_2_end != blank
    assign p2_end_ts = section.settings.phase_2_end | append: ' 23:59:59' | date: '%s' | plus: 0
  endif
  if section.settings.phase_3_start != blank
    assign p3_start_ts = section.settings.phase_3_start | append: ' 00:00:00' | date: '%s' | plus: 0
  endif
  if section.settings.phase_3_end != blank
    assign p3_end_ts = section.settings.phase_3_end | append: ' 23:59:59' | date: '%s' | plus: 0
  endif

  assign active_phase = 0
  assign active_discount = 0
  assign active_code = ''
  assign active_title = ''
  assign active_label = ''
  assign active_start_ts = 0
  assign active_end_ts = 0
  assign active_shipping_note_1 = ''
  assign active_shipping_note_2 = ''
  assign active_shipping_text = ''
  assign active_tagline = ''
  assign active_phase_name = ''

  if section.settings.offer_enabled
    if now_ts >= p1_start_ts and now_ts <= p1_end_ts
      assign active_phase = 1
      assign active_discount = section.settings.phase_1_discount | plus: 0
      assign active_code = section.settings.phase_1_discount_code
      assign active_title = section.settings.phase_1_title
      assign active_label = section.settings.phase_1_label
      assign active_start_ts = p1_start_ts
      assign active_end_ts = p1_end_ts
      assign active_shipping_note_1 = section.settings.phase_1_shipping_note1
      assign active_shipping_note_2 = section.settings.phase_1_shipping_note2
      assign active_shipping_text = 'In your hands in ~14 days'
      assign active_tagline = 'Yours before<br><em>the rest of the world.</em>'
      assign active_phase_name = 'Drop 1'
    elsif now_ts >= p2_start_ts and now_ts <= p2_end_ts
      assign active_phase = 2
      assign active_discount = section.settings.phase_2_discount | plus: 0
      assign active_code = section.settings.phase_2_discount_code
      assign active_title = section.settings.phase_2_title
      assign active_label = section.settings.phase_2_label
      assign active_start_ts = p2_start_ts
      assign active_end_ts = p2_end_ts
      assign active_shipping_note_1 = section.settings.phase_2_shipping_note1
      assign active_shipping_note_2 = section.settings.phase_2_shipping_note2
      assign active_shipping_text = 'In your hands in ~30 days'
      assign active_tagline = 'Yours before<br><em>the rest of the world.</em>'
      assign active_phase_name = 'Drop 2'
    elsif section.settings.enable_phase_3 and now_ts >= p3_start_ts and now_ts <= p3_end_ts
      assign active_phase = 3
      assign active_discount = section.settings.phase_3_discount | plus: 0
      assign active_code = section.settings.phase_3_discount_code
      assign active_title = section.settings.phase_3_title
      assign active_label = section.settings.phase_3_label
      assign active_start_ts = p3_start_ts
      assign active_end_ts = p3_end_ts
      assign active_shipping_note_1 = section.settings.phase_3_shipping_note1
      assign active_shipping_note_2 = section.settings.phase_3_shipping_note2
      assign active_shipping_text = 'In your hands in ~60 days'
      assign active_tagline = 'Available now<br><em>for everyone</em>'
      assign active_phase_name = 'Public Release'
    endif
  endif

  assign offer_active = false
  if active_phase > 0
    assign offer_active = true
  endif

  assign seconds_left = active_end_ts | minus: now_ts
  assign days_left = seconds_left | plus: 86399 | divided_by: 86400
  assign phase_total = active_end_ts | minus: active_start_ts
  assign remaining_percent = 100
  if phase_total > 0
    assign remaining_percent = seconds_left | times: 100 | divided_by: phase_total
  endif
  if remaining_percent < 0
    assign remaining_percent = 0
  endif
  if remaining_percent > 100
    assign remaining_percent = 100
  endif

  assign offer_collection = section.settings.product_collection

  assign ref_product_price = 0
  for _p in offer_collection.products
    if _p.available
      assign ref_product_price = _p.price_min
      break
    endif
  endfor

  assign p1_d = section.settings.phase_1_discount | plus: 0
  assign p2_d = section.settings.phase_2_discount | plus: 0
  assign p3_d = section.settings.phase_3_discount | plus: 0

  assign p1_price_display = ref_product_price
  if p1_d > 0 and ref_product_price > 0
    assign p1_mult = 100 | minus: p1_d
    assign p1_price_display = ref_product_price | times: p1_mult | divided_by: 100
  endif

  assign p2_price_display = ref_product_price
  if p2_d > 0 and ref_product_price > 0
    assign p2_mult = 100 | minus: p2_d
    assign p2_price_display = ref_product_price | times: p2_mult | divided_by: 100
  endif

  assign p3_price_display = ref_product_price
  if p3_d > 0 and ref_product_price > 0
    assign p3_mult = 100 | minus: p3_d
    assign p3_price_display = ref_product_price | times: p3_mult | divided_by: 100
  endif
%}

{% assign circle_return_url = request.path %}

<section
  class="circle-access circle-{{ sid }}"
  data-has-phase-3="{{ section.settings.enable_phase_3 }}"
  data-circle-section="{{ sid }}"
  data-active-phase="{{ active_phase }}"
  data-discount-percent="{{ active_discount }}"
  data-discount-code="{{ active_code | escape }}"
  data-active-end-ms="{{ active_end_ts | times: 1000 }}"
  data-button-action="{{ section.settings.button_action }}"
  data-access-codes="{{ section.settings.access_codes | escape }}"
  data-phase-1-discount="{{ section.settings.phase_1_discount | plus: 0 }}"
  data-phase-2-discount="{{ section.settings.phase_2_discount | plus: 0 }}"
  data-phase-3-discount="{{ section.settings.phase_3_discount | plus: 0 }}"
  data-phase-name="{{ active_phase_name }}"
  data-shipping-text="{{ active_shipping_text }}"
  data-tagline="{{ active_tagline | escape }}"
>
  <!-- LOGGED IN: JS decides whether to show code gate or offer -->
  <div class="circle-shell">
    {%- render 'circle_login',
      sid: section.id,
      gate_placeholder: section.settings.gate_placeholder,
      gate_button_text: section.settings.gate_button_text,
      gate_error_text: section.settings.gate_error_text
    -%}

    <!-- FULL OFFER CONTENT -->
    <div class="circle-offer-content" id="circle-offer-content-{{ sid }}" style="display:none;">
      <nav class="circle-nav">
        <div class="circle-nav-right">
          <div class="circle-member-pill">{{ section.settings.member_label }}</div>
          {% if customer %}
            <a href="{{ routes.account_logout_url }}" class="circle-signout">{{ section.settings.signout_text }}</a>
          {% endif %}
        </div>
      </nav>

      {% if offer_active %}
        <div class="circle-hero">
          <div class="circle-live-line">
            <span class="circle-live-dot"></span>
            {{ active_label }} open now
          </div>
          <h1>
            {{ section.settings.welcome_heading }}
            <br>
            <em>{{ section.settings.welcome_emphasis }}</em>
          </h1>
          <p class="circle-hero-sub">
            <p class="hero-sub">Members get every release first, before public launch.</p>
          </p>
        </div>

        <!-- PHASE STRIP -->
        {%- liquid
          assign strip_cols = 3
          if active_phase == 1 and section.settings.enable_phase_3 == false
            assign strip_cols = 2
          endif
        -%}
        <div
          class="circle-drop-strip"
          style="grid-template-columns: {% if active_phase == 1 %}1fr 1fr{% else %}1fr 1.2fr 1fr{% endif %};"
        >
          <!-- Phase 1 - Always shown -->
          <div class="circle-drop-cell {% if active_phase == 1 %}active-drop{% else %}locked{% endif %}">
            <div class="circle-drop-num">Drop 1</div>

            {% if active_phase == 1 %}
              <div class="circle-drop-ships">Arrives Within ~14 Days</div>
            {% endif %}

            <div
              class="circle-drop-price"
              data-strip-price="1"
              data-phase-discount="{{ section.settings.phase_1_discount | plus: 0 }}"
            >
              {% if ref_product_price > 0 %}
                {% if p1_d > 0 %}
                  {{ p1_price_display | money }}
                {% else %}
                  {{ ref_product_price | money }}
                {% endif %}
              {% else %}
                {{ p1_d }}% off
              {% endif %}
            </div>
            {% if active_phase == 2 %}
              <div class="drop-label_circle">The Circle</div>
            {% endif %}
            {% unless active_phase == 1 %}
              <div class="circle-drop-tag">
                {% if active_phase > 1 %}
                  Closed
                {% else %}
                  Locked
                {% endif %}
              </div>
            {% endunless %}
          </div>

          <!-- Phase 2 - Show conditionally -->
          {% unless active_phase == 1 and section.settings.enable_phase_3 == false %}
            <div class="circle-drop-cell {% if active_phase == 2 %}active-drop{% elsif active_phase > 2 %}locked{% else %}locked{% endif %} phase-2">
              <div class="circle-drop-num">Drop 2</div>

              {% if active_phase == 2 %}
                <div class="circle-drop-ships">Ships in ~30 days</div>
              {% endif %}

              <div
                class="circle-drop-price"
                data-strip-price="2"
                data-phase-discount="{{ section.settings.phase_2_discount | plus: 0 }}"
              >
                {% if ref_product_price > 0 %}
                  {% if p2_d > 0 %}
                    {{ p2_price_display | money }}
                  {% else %}
                    {{ ref_product_price | money }}
                  {% endif %}
                {% else %}
                  {{ p2_d }}% off
                {% endif %}
              </div>
              <div class="circle-drop-label">{{ section.settings.phase_2_short }}</div>
              <div class="circle-drop-tag">
                {% if active_phase == 2 %}Open now{% elsif active_phase > 2 %}Closed{% else %}Locked{% endif %}
              </div>
            </div>
          {% endunless %}

          <!-- Phase 3 / Public Release -->
          {% if section.settings.enable_phase_3 %}
            <div class="circle-drop-cell {% if active_phase == 3 %}active-drop{% else %}locked{% endif %}">
              <div class="circle-drop-num">Public Release</div>

              {% if active_phase == 1 or active_phase == 2 %}
                <div class="circle-drop-ships_phase_3">Arrives Within ~60 Days</div>
              {% endif %}

              <div class="circle-drop-label">No member benefits</div>
              <div
                class="circle-drop-price"
                data-strip-price="3"
                data-phase-discount="{{ section.settings.phase_3_discount | plus: 0 }}"
              >
                {% if ref_product_price > 0 %}
                  {% if p3_d > 0 %}
                    {{ p3_price_display | money }}
                  {% else %}
                    {{ ref_product_price | money }}
                  {% endif %}
                {% else %}
                  {% if p3_d > 0 %}{{ p3_d }}% off{% else %}Full price{% endif %}
                {% endif %}
              </div>
            </div>
          {% else %}
            <div class="circle-drop-cell public-release">
              <div class="circle-drop-num">Public Release</div>
              <div class="circle-drop-price" data-strip-price="public">
                {% if ref_product_price > 0 %}{{ ref_product_price | money }}{% else %}Full price{% endif %}
              </div>
              <div class="circle-drop-label">
                {{ section.settings.public_release_label | default: 'No member benefits' }}
              </div>
              <div class="circle-drop-tag">Coming soon</div>
            </div>
          {% endif %}
        </div>

        <!-- PRODUCTS CARD -->
        <div class="circle-card circle-products-card">
          <div class="circle-card-label">{{ section.settings.product_heading }}</div>

          {%- liquid
            assign displayed_products_count = 0
            for product in offer_collection.products
              if section.settings.hide_sold_out_products and product.available == false
                continue
              endif
              assign displayed_products_count = displayed_products_count | plus: 1
            endfor
          -%}

          {% if offer_collection != blank and displayed_products_count > 0 %}
            <div class="circle-slider-wrapper" data-slider>
              <button
                type="button"
                class="circle-arrow circle-arrow-prev"
                data-arrow="prev"
                aria-label="Previous"
                disabled
              >
                <svg
                  viewBox="0 0 24 24"
                  width="16"
                  height="16"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="15 18 9 12 15 6"></polyline>
                </svg>
              </button>
              <div class="circle-slider-viewport" data-slider-viewport>
                <div class="circle-slider-track" data-slider-track>
                  {% assign loop_index = 0 %}
                  {% for product in offer_collection.products %}
                    {% if section.settings.hide_sold_out_products and product.available == false %}
                      {% continue %}
                    {% endif %}
                    {% liquid
                      assign sale_price = product.price_min
                      if active_discount > 0
                        assign discount_multiplier = 100 | minus: active_discount
                        assign sale_price = product.price_min | times: discount_multiplier | divided_by: 100
                      endif
                    %}
                    <div
                      class="circle-prod {% unless product.available %}sold{% endunless %}"
                      data-product-index="{{ loop_index }}"
                      data-product-id="{{ product.id }}"
                    >
                      <div class="circle-prod-img">
                        <span class="circle-prod-dot"></span>
                        {% if product.featured_image %}
                          <img
                            src="{{ product.featured_image | image_url: width: 500 }}"
                            alt="{{ product.featured_image.alt | default: product.title | escape }}"
                            loading="lazy"
                            data-product-featured-image
                            width="auto"
                            height="auto"
                          >
                        {% else %}
                          <span class="circle-prod-icon">🛍</span>
                        {% endif %}
                      </div>
                      <div class="circle-prod-info">
                        <div class="circle-prod-name">{{ product.title }}</div>
                        {% comment %} {% if product.available %}
                          <div class="circle-prod-pricing">
                            <span data-product-price-display>{{ sale_price | money }}</span>
                            {% if active_discount > 0 %}
                              <s data-product-compare-price-display>{{ product.price_min | money }}</s>
                            {% endif %}
                          </div>
                        {% else %}
                          <div class="circle-prod-status sold-label">Sold out</div>
                        {% endif %} {% endcomment %}
                      </div>
                      {% comment %} <button
                        type="button"
                        class="circle-prod-details-btn"
                        data-prod-details-btn
                        data-product-id="{{ product.id }}"
                        data-product-index="{{ loop_index }}"
                        aria-label="View product details"
                      >
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="14"
                          height="14"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <circle cx="11" cy="11" r="8"></circle>
                          <path d="M11 8v6M8 11h6"></path>
                        </svg>
                        <span>View Product</span>
                      </button> {% endcomment %}
                      {% comment %} <div class="prod-status"
                        data-prod-details-btn
                        data-product-id="{{ product.id }}"
                        data-product-index="{{ loop_index }}"
                        aria-label="View product details"
                        style="color:var(--forest);">
                        Tap to view →
                      </div> {% endcomment %}
                      <div class="prod-status-wrapper" data-product-index="{{ loop_index }}">
  {% if product.available %}
    <div class="prod-status status-active" 
      data-prod-details-btn
      data-product-id="{{ product.id }}"
      data-product-index="{{ loop_index }}"
      aria-label="View product details"
      style="color:var(--forest);cursor:pointer;display:none;">
      Tap to view →
    </div>
    <div class="prod-status status-shipping" style="color:#9a9792;font-size:8px;letter-spacing:0.08em;text-transform:uppercase;">
      {% if active_phase == 1 %}
        Ships in ~14 days
      {% elsif active_phase == 2 %}
        Ships in ~30 days
      {% elsif active_phase == 3 %}
        Ships in ~60 days
      {% else %}
        Available now
      {% endif %}
    </div>
  {% else %}
    <div class="prod-status" style="color:#9a9792;font-size:8px;letter-spacing:0.08em;text-transform:uppercase;">
      Sold out
    </div>
  {% endif %}
</div>
                    </div>
                    {% assign loop_index = loop_index | plus: 1 %}
                  {% endfor %}
                </div>
              </div>
              <button type="button" class="circle-arrow circle-arrow-next" data-arrow="next" aria-label="Next">
                <svg
                  viewBox="0 0 24 24"
                  width="16"
                  height="16"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
              </button>
            </div>
            <div class="circle-slider-dots" data-slider-dots></div>
          {% else %}
            <div class="circle-empty">Please select a collection from this section settings.</div>
          {% endif %}
        </div>

        <!-- VARIANT OPTIONS + SIZE GUIDE -->
        <div class="circle-inline-options-container" data-options-container></div>

        <!-- RESERVE CARD -->
        <div class="circle-action-block">
          <div class="circle-action-eyebrow">{{ active_label }} — {{ active_title }}</div>
          <div style="margin-bottom:10px;">
            <span
              class="drop-tag"
              style="background:var(--forest-tint);color:var(--forest);font-size:9px;letter-spacing:0.16em;text-transform:uppercase;padding:6px 16px;border-radius:99px;display:inline-block;"
              >Open now</span
            >
          </div>

          <div class="circle-countdown-wrap">
            <div class="circle-countdown-label">{{ active_label }} ends in</div>
            <div class="circle-countdown">
              <div class="circle-t-block">
                <span class="circle-t-num" data-days>00</span><span class="circle-t-lbl">Days</span>
              </div>
              <span class="circle-t-sep">:</span>
              <div class="circle-t-block">
                <span class="circle-t-num" data-hours>00</span><span class="circle-t-lbl">Hrs</span>
              </div>
              <span class="circle-t-sep">:</span>
              <div class="circle-t-block">
                <span class="circle-t-num" data-minutes>00</span><span class="circle-t-lbl">Min</span>
              </div>
              <span class="circle-t-sep">:</span>
              <div class="circle-t-block">
                <span class="circle-t-num" data-seconds>00</span><span class="circle-t-lbl">Sec</span>
              </div>
            </div>
          </div>

          <div class="circle-price-block">
            <div class="circle-price-main">
              <div class="circle-price-context">Your price today</div>
              <div style="display: flex;">
                <div class="circle-price-amount" data-preview-sale-price>—</div>
                <span
                  class="inner_circle"
                  style="font-size:18px;font-weight:300;color:#1a3a2a;  margin-left: 10px; font-family: Cormorant Garamond";
                >
                  (Inner Circle)</span
                >
              </div>
            </div>
            <div class="circle-price-future">
              <div class="circle-price-context">Public Release</div>
              <div class="circle-price-was" data-preview-compare-price>—</div>
            </div>
          </div>

          <button type="button" class="circle-cta-btn" data-reserve-main>
            {{ section.settings.reserve_button_text }}
          </button>
          <div class="circle-cta-meta">
            <p>{{ active_shipping_note_1 }}</p>
            <p>{{ active_shipping_note_2 }}</p>
          </div>
        </div>

        <!-- NEXT PHASE / NOTIFY CARD -->
        {% if active_phase == 1 %}
          <!-- Drop 2 Row -->
          <div class="circle-locked-row">
            <div class="circle-locked-left">
              <div class="circle-locked-eyebrow">Drop 2 — Opens after Drop 1</div>
              <div class="circle-locked-title">{{ section.settings.phase_2_title | default: 'Second Release' }}</div>
            </div>
            <div class="circle-locked-right">
              <div class="circle-locked-price-wrapper">
                <span class="circle-locked-price-amount" data-locked-price-2 data-phase-discount="{{ p2_d }}">—</span>
              </div>
              <div class="locked-when" data-locked-when-2>Ships in ~30–40 days</div>
            </div>
          </div>

          <!-- Drop 3 Row (if enabled) -->
          {% if section.settings.enable_phase_3 %}
            <div class="circle-locked-row">
              <div class="circle-locked-left">
                <div class="circle-locked-eyebrow">Drop 3 — Public release</div>
                <div class="circle-locked-title">
                  {{ section.settings.phase_3_title | default: 'No member benefits' }}
                </div>
              </div>
              <div class="circle-locked-right">
                <div class="circle-locked-price-wrapper">
                  <span class="circle-locked-price-amount" data-locked-price-3 data-phase-discount="{{ p3_d }}">—</span>
                </div>
                <div class="locked-when" data-locked-when-3>Ships in ~50–60 days</div>
              </div>
            </div>
          {% endif %}

        {% elsif active_phase == 2 %}
          <!-- Show Drop 3 only (if enabled) -->
          {% if section.settings.enable_phase_3 %}
            <div class="circle-locked-row">
              <div class="circle-locked-left">
                <div class="circle-locked-eyebrow">Drop 3 — Public release</div>
                <div class="circle-locked-title">Open to everyone</div>
              </div>
              <div class="circle-locked-right">
                <div class="circle-locked-price-wrapper">
                  <span class="circle-locked-price-amount" data-locked-price data-phase-discount="{{ p3_d }}">—</span>
                </div>
              </div>
            </div>
          {% else %}
            <!-- Public Release Row (when no Phase 3) -->
            <div class="circle-locked-row">
              <div class="circle-locked-left">
                <div class="circle-locked-eyebrow">Public Release — Coming soon</div>
                <div class="circle-locked-title">Open to everyone</div>
              </div>
              <div class="circle-locked-right">
                <div class="circle-locked-price-wrapper">
                  <span class="circle-locked-price-amount" data-locked-price data-phase-discount="0">—</span>
                </div>
              </div>
            </div>
          {% endif %}

        {% elsif active_phase == 3 %}
          <!-- Offer Ended State -->
          <div class="circle-locked-row">
            <div class="circle-locked-left">
              <div class="circle-locked-eyebrow">Final phase — Offer ended</div>
              <div class="circle-locked-title">
                {{ section.settings.ended_heading | default: 'This offer has ended' }}
              </div>
            </div>
            <div class="circle-locked-right">
              <div class="circle-locked-price-wrapper">
                <span class="circle-locked-price-amount" data-locked-price>Closed</span>
              </div>
              <div class="locked-when">No longer available</div>
            </div>
          </div>
        {% endif %}

      {% else %}
        <!-- ENDED STATE -->
        <div class="circle-login-card circle-ended-card">
          <div class="circle-login-eyebrow">{{ section.settings.ended_eyebrow }}</div>
          <h1>{{ section.settings.ended_heading }}</h1>
          <p>{{ section.settings.ended_text }}</p>
          {% if customer and customer.accepts_marketing %}
            <div class="circle-already-subscribed">
              <strong>You're already on the list.</strong>
              <p>We'll notify you when the next Circle offer launches.</p>
            </div>
          {% else %}
            {% form 'customer', class: 'circle-waitlist-form ended' %}
              <input type="hidden" name="contact[tags]" value="circle-waitlist">
              <input
                type="email"
                name="contact[email]"
                value=""
                placeholder="Email address"
                required
              >
              <button type="submit" class="circle-main-btn">{{ section.settings.ended_button_text }}</button>
            {% endform %}
          {% endif %}
        </div>
      {% endif %}
    </div>
    <!-- /.circle-offer-content -->
  </div>
